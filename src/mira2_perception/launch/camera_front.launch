<!-- camera_reader_uvc.launch.xml -->
<launch>

    <!-- Streaming parameters -->
    <arg name="stream"        default="true"/>
    <arg name="vendor_id"     default="0x0c45"/>
    <arg name="product_id"    default="0x6366"/>
    <arg name="serial_no"     default="SN0001"/>
    <arg name="image_width"   default="1280"/>
    <arg name="image_height"  default="720"/>
    <arg name="frame_format"  default="MJPEG"/>
    <arg name="framerate"     default="30"/>
    <arg name="port" default="2000" />
    <arg name="camera_frame_id" default="camera_front" />

    <node pkg="camera_driver"
          exec="camera_driver_exe"
          name="camera_front_driver"
          output="screen">
        <param name="image_width"   value="$(var image_width)"/>
        <param name="image_height"  value="$(var image_height)"/>
        <param name="frame_format"  value="$(var frame_format)"/>
        <param name="framerate"     value="$(var framerate)" />
        <param name="port" value="2001"/>
        <param name="usb_port" value="usb-3610000.usb-2.1" />
		<param name="camera_frame_id" value="$(var camera_frame_id)"/>
    </node>
      <executable cmd="sleep 2 ; gst-launch-1.0 rtspsrc location=rtsp://127.0.0.1:$(var port)/image_rtsp ! fakesink" cwd="/home" shell="true"/>
 </launch>
